{
  "name": "@profidev/iroh-ffi",
  "version": "1.1.0",
  "description": "Iroh bindings for the Browser.",
  "homepage": "https://github.com/Profiidev/iroh-ffi#readme",
  "bugs": {
    "url": "https://github.com/Profiidev/iroh-ffi/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Profiidev/iroh-ffi"
  },
  "license": "GPL-2.0",
  "author": "ProfiDev",
  "type": "module",
  "scripts": {
    "build": "cargo build --target=wasm32-unknown-unknown && wasm-bindgen ./target/wasm32-unknown-unknown/debug/iroh_ffi.wasm --out-dir ./dist --target web --debug",
    "build:release": "cargo build --release --target=wasm32-unknown-unknown && wasm-bindgen ./target/wasm32-unknown-unknown/release/iroh_ffi.wasm --out-dir ./dist --target web"
  },
  "files": [
    "dist/"
  ],
  "types": "dist/iroh_ffi.d.ts"
}
